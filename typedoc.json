{
  "$schema": "https://typedoc.org/schema.json",
  "plugin": ["typedoc-plugin-markdown"],
  "entryPoints": ["src/index.ts", "src/testing/index.ts"],
  "out": "docs/site/reference",
  "excludeInternal": true,
  "excludePrivate": true,
  "readme": "none",
  "githubPages": false,
  "hidePageHeader": true,
  "hideBreadcrumbs": true,
  "useCodeBlocks": true,
  "entryFileName": "index",
  "mergeReadme": false,
  "sort": ["source-order"]
}
