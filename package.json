{
  "name": "agent-harness-sdk",
  "version": "0.0.0",
  "description": "Primitives for building agent harnesses: tools, guards, checks, hooks, observability.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./hooks/pre-tool-use": "./dist/hooks/pre-tool-use.js",
    "./hooks/post-tool-use": "./dist/hooks/post-tool-use.js",
    "./mcp/start": "./dist/mcp/start.js"
  },
  "files": [
    "dist",
    "src/skills",
    "src/rules",
    "src/commands",
    "scripts",
    "README.md"
  ],
  "bin": {
    "harness": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "postinstall": "node ./scripts/postinstall.js"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3 || ^4"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^20",
    "typescript": "^5",
    "vite": "^8.0.11",
    "vite-plugin-dts": "^5.0.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  }
}
