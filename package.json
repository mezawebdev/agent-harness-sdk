{
  "name": "agent-harness-sdk",
  "version": "0.3.3",
  "description": "Primitives for building agent harnesses: tools, guards, checks, hooks, observability.",
  "license": "MIT",
  "author": "Alex Meza",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mezawebdev/agent-harness-sdk.git"
  },
  "homepage": "https://github.com/mezawebdev/agent-harness-sdk#readme",
  "bugs": {
    "url": "https://github.com/mezawebdev/agent-harness-sdk/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "agent-harness",
    "mcp",
    "model-context-protocol",
    "hooks",
    "tools",
    "guards",
    "checks"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./hooks/pre-tool-use": "./dist/hooks/pre-tool-use.js",
    "./hooks/post-tool-use": "./dist/hooks/post-tool-use.js",
    "./hooks/session-start": "./dist/hooks/session-start.js",
    "./hooks/user-prompt-submit": "./dist/hooks/user-prompt-submit.js",
    "./mcp/start": "./dist/mcp/start.js"
  },
  "files": [
    "dist",
    "src/skills",
    "src/rules",
    "src/commands",
    "README.md"
  ],
  "bin": {
    "harness": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "docs:api": "typedoc",
    "docs:dev": "npm run docs:api && vitepress dev docs/site",
    "docs:build": "npm run docs:api && vitepress build docs/site",
    "docs:preview": "vitepress preview docs/site"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/picomatch": "^4.0.3",
    "mermaid": "^11.15.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5",
    "vite": "^8.0.11",
    "vite-plugin-dts": "^5.0.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  }
}
