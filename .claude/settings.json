{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx --no-install tsx $CLAUDE_PROJECT_DIR/src/hooks/pre-tool-use.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx --no-install tsx $CLAUDE_PROJECT_DIR/src/hooks/post-tool-use.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx --no-install tsx $CLAUDE_PROJECT_DIR/src/hooks/session-start.ts"
          }
        ]
      }
    ]
  }
}
